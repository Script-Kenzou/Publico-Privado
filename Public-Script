-- Auto Lift
AutoLiftButton.MouseButton1Click:Connect(function()
	autoLift = not autoLift
	AutoLiftButton.Text = autoLift and "Auto Lift: ON" or "Auto Lift: OFF"
	TweenService:Create(AutoLiftButton, TweenInfo.new(0.2), {BackgroundColor3 = autoLift and Color3.fromRGB(124, 58, 237) or Color3.fromRGB(30, 30, 30)}):Play()
    notify("Auto Lift", autoLift and "Enabled successfully!" or "Disabled successfully!", autoLift and Color3.fromRGB(124, 58, 237) or Color3.fromRGB(239, 68, 68))
end)

