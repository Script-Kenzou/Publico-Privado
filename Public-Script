-- Anti-AFK (Bypasses Roblox Idle disconnect kick)
AntiAFKButton.MouseButton1Click:Connect(function()
	antiAFK = not antiAFK
	AntiAFKButton.Text = antiAFK and "Anti-AFK: ON" or "Anti-AFK: OFF"
	TweenService:Create(AntiAFKButton, TweenInfo.new(0.2), {BackgroundColor3 = antiAFK and Color3.fromRGB(245, 158, 11) or Color3.fromRGB(30, 30, 30)}):Play()
    
    if antiAFK then
        notify("Anti-AFK Active", "You won't be kicked for idling!", Color3.fromRGB(245, 158, 11))
    else
        notify("Anti-AFK Inactive", "Standard AFK kick is now active.", Color3.fromRGB(239, 68, 68))
    end
end)

-- Hooking Roblox Connection for Anti-AFK
LocalPlayer.Idled:Connect(function()
    if antiAFK then
        VirtualUser:Button2Down(Vector2.new(0, 0), workspace.CurrentCamera.CFrame)
        task.wait(1)
        VirtualUser:Button2Up(Vector2.new(0, 0), workspace.CurrentCamera.CFrame)
    end
end)

